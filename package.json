{
  "name": "nft-bot-system",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/bot-core",
    "apps/bot-discord",
    "apps/frontend"
  ],
  "scripts": {
    "dev": "concurrently --names \"API,BOT,FRONT\" --prefix-colors \"cyan,yellow,magenta\" \"npm run dev:api\" \"npm run dev:bot\" \"npm run dev:front\"",
    "dev:api": "cd apps/api && node --watch index.js",
    "dev:bot": "cd apps/bot-core && node --watch src/index.js",
    "dev:front": "cd apps/frontend && npm run dev",
    "db:generate": "prisma generate --schema=apps/api/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=apps/api/prisma/schema.prisma",
    "db:migrate:prod": "prisma migrate deploy --schema=apps/api/prisma/schema.prisma",
    "db:studio": "cd apps/api && npx prisma studio",
    "seed": "npm run seed --workspace=apps/api",
    "api": "npm run start --workspace=apps/api",
    "bot-core": "npm run start --workspace=apps/bot-core",
    "bot-discord": "npm run start --workspace=apps/bot-discord"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prisma": "^5.22.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  }
}
