generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String           @id @default(uuid())
  email          String           @unique
  passwordHash   String
  role           String           @default("trader")
  // Wallet — clé chiffrée AES-256-GCM, jamais en clair
  walletAddress  String?
  walletKeyEnc   String?
  // Config bot par user
  paperTrading      Boolean  @default(true)
  budgetMaxEth      Float    @default(1.0)
  maxGasGwei        Int      @default(35)
  offerExpiryMin    Int      @default(1440)
  timeoutSellH      Int      @default(72)
  relistAfterMin    Int      @default(15)
  autoWrapAfterSale Boolean  @default(true)
  ethReserveGas     Float    @default(0.01)
  botEnabled        Boolean  @default(false)
  discordWebhook    String?
  createdAt      DateTime         @default(now())
  collections    UserCollection[]
  trades         Trade[]
  offers         Offer[]
  logs           BotLog[]
  snipeConfig    SnipeConfig?
}

model UserCollection {
  id                String   @id @default(uuid())
  userId            String
  collectionAddress String
  collectionName    String
  enabled            Boolean  @default(true)
  // Config obligatoire par collection (offres)
  offerBelowFloorPct Float
  stopLossPct        Float
  offerMaxActive     Int      @default(5)
  // Config snipe par collection (optionnel)
  snipeEnabled   Boolean  @default(false)
  snipeFloorPct  Float?   // % au-dessus du floor : 0 = au floor, 5 = floor+5%, -5 = 5% sous floor
  snipeMaxRank   Int?     // rang max de rareté (inclus) : 100 → achète si rank <= 100
  createdAt          DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, collectionAddress])
  @@index([userId])
}

model Trade {
  id           String    @id @default(uuid())
  userId       String
  tokenId      String
  collection   String
  source       String
  buyPrice     Float
  buyTxHash    String?
  listPrice    Float?
  sellPrice    Float?
  sellTxHash   String?
  gasBuy       Float?
  gasSell      Float?
  pnl          Float?
  status       String
  isPaperTrade Boolean   @default(true)
  boughtAt     DateTime  @default(now())
  listedAt     DateTime?
  soldAt       DateTime?
  user         User      @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([userId, boughtAt])
}

model Offer {
  id           String    @id @default(uuid())
  userId       String
  collection   String
  offerPrice   Float
  floorAtOffer Float
  offerTxHash  String?
  status       String
  isPaperTrade Boolean   @default(true)
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  acceptedAt   DateTime?
  user         User      @relation(fields: [userId], references: [id])

  @@index([userId, status])
}

model FloorSnapshot {
  id         String   @id @default(uuid())
  collection String
  floorPrice Float
  volume24h  Float?
  listings   Int?
  recordedAt DateTime @default(now())

  @@index([collection, recordedAt])
}

model SnipeConfig {
  id             String   @id @default(uuid())
  userId         String   @unique
  walletAddress  String?
  walletKeyEnc   String?
  paperTrading   Boolean  @default(true)
  enabled        Boolean  @default(false)
  budgetMaxEth   Float    @default(1.0)
  maxGasGwei     Int      @default(35)
  maxPositions   Int      @default(3)
  ethReserveGas  Float    @default(0.01)
  discordWebhook String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BotLog {
  id        String   @id @default(uuid())
  userId    String?
  level     String
  module    String
  message   String
  data      Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([level, createdAt])
}
